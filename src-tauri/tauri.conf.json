{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reader",
  "version": "4.0.0",
  "identifier": "com.local.reader",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reader",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1200,
        "height": 780,
        "minWidth": 860,
        "minHeight": 540,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/snibo-scale/Reader/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNDMjc5OTdENDc0MUUwNEUKUldSTzRFRkhmWmtuUEFyQy83Q1E1TTFiRTlkc3NBWFJJbG5iLy95bTlHYk9kTkVNbVFiejQ3aHAK"
    }
  }
}
